# ════════════════════════════════════════════════════════════════════
# Léguas Franzinas — .gitignore
# ════════════════════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── Django ──────────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
celerybeat-schedule
celerybeat-schedule.db

# ── Environment variables (NUNCA commit) ────────────────────────────
.env
.env.*
!.env.example
!production/.env.example

# ── Production runtime ──────────────────────────────────────────────
production/.env
production/backups/
production/caddy_data/

# ── Backups ─────────────────────────────────────────────────────────
backups/
*.backup
*_backup
*.bak

# ── IDE / Editor ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ── Claude Code agent memory (privado) ──────────────────────────────
.claude/

# ── OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ──────────────────────────────────────────────────────────
*.pid
docker-compose.override.yml

# ── Debug / temp / lixo ─────────────────────────────────────────────
debug_files/
files/
tmp/
temp/
*.tmp

# ── Sessões scraping ────────────────────────────────────────────────
delnext_session.pkl
*.session
*.pkl

# ── Node modules (se houver) ────────────────────────────────────────
node_modules/
package-lock.json

# ── Testes / coverage ───────────────────────────────────────────────
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# ── Outros ──────────────────────────────────────────────────────────
.dump
*.dump
*.sql
!init-db.sql
