# ════════════════════════════════════════════════════════════════════
# Léguas Franzinas — Production Environment
# ════════════════════════════════════════════════════════════════════
# 1. Copia este ficheiro para .env:
#       cp .env.example .env
# 2. Preenche TODAS as variáveis marcadas com [OBRIGATÓRIO]
# 3. NUNCA faças commit do .env (já está no .gitignore)
# ════════════════════════════════════════════════════════════════════


# ──────────────────────────── DJANGO ────────────────────────────────
# [OBRIGATÓRIO] Gerar com: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-random-50char-string

# Em produção sempre False
DEBUG=False

# [OBRIGATÓRIO] Domínio + subdomínios + IP do servidor
# Ex: app.leguasfranzinas.pt,www.leguasfranzinas.pt,192.0.2.1
ALLOWED_HOSTS=localhost,127.0.0.1

# [OBRIGATÓRIO se HTTPS] origens confiáveis para CSRF
CSRF_TRUSTED_ORIGINS=http://localhost,https://localhost

# Forçar HTTPS (auto-detecta se Caddy emite cert)
FORCE_HTTPS=True


# ──────────────────────── ENCRIPTAÇÃO ──────────────────────────────
# [OBRIGATÓRIO] Chave Fernet para encriptar campos sensíveis na BD
# Gerar com: docker compose run --rm web python manage.py generate_fernet_key
FERNET_KEY=change-me-fernet-key


# ────────────────────────── BASE DE DADOS ──────────────────────────
DB_NAME=leguas_db
DB_USER=leguas_user
DB_PASSWORD=change-me-strong-password
DB_ROOT_PASSWORD=change-me-root-password
DB_HOST=db
DB_PORT=3306


# ────────────────────────── REDIS ──────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# ─────────────────────── ADMIN INICIAL ─────────────────────────────
# Auto-criados na primeira instalação. Apaga estas vars depois.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@leguasfranzinas.pt
DJANGO_SUPERUSER_PASSWORD=change-me-strong-admin-password


# ────────────────────── DOMÍNIO + SSL (Caddy) ──────────────────────
# DOMAIN: domínio real para SSL automático Let's Encrypt
# Deixar `:80` para HTTP-only (sem SSL, útil em VPN/dev/IP)
# Exemplo produção: app.leguasfranzinas.pt
DOMAIN=:80

# Email para Let's Encrypt notificar expiração (só se DOMAIN é real)
LETSENCRYPT_EMAIL=admin@leguasfranzinas.pt


# ────────────────────── WPPCONNECT (WhatsApp) ──────────────────────
WPPCONNECT_URL=http://wppconnect:21465
# [OBRIGATÓRIO] Secret partilhado — gerar com openssl rand -hex 32
WPPCONNECT_SECRET=change-me-wpp-secret
WPPCONNECT_TOKEN=change-me-wpp-token
WPPCONNECT_INSTANCE=leguas_wppconnect

# Grupo onde enviar relatórios automáticos (formato: ABC123@g.us)
WHATSAPP_REPORT_GROUP=
WHATSAPP_API_URL=


# ─────────────────────── CAINIAO (Paack) ───────────────────────────
API_URL=
COOKIE_KEY=
SYNC_TOKEN=
INTERNAL_API_URL=


# ─────────────────────── DELNEXT (Playwright) ──────────────────────
DELNEXT_ORIGIN_URL=
DELNEXT_LOGIN_URL=
DELNEXT_STATS_URL=
DELNEXT_ADMIN_NAME=
DELNEXT_ADMIN_PASS=


# ───────────────────── GEOAPI.PT (Geocoding) ───────────────────────
GEOAPI_TOKEN=


# ─────────────────────── BACKUP ────────────────────────────────────
# Password do ZIP de backup (FTP)
BACKUP_ZIP_PASSWORD=change-me-backup-zip-password


# ─────────────────────── EVOLUTION API (legacy, opcional) ──────────
# Só preencher se quiseres usar Evolution API em vez do WPPConnect
AUTHENTICATION_API_KEY=


# ─────────────────────── GUNICORN TUNING (opcional) ────────────────
# Auto-detecta CPU se não definido
# GUNICORN_WORKERS=4
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info
